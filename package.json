{
  "name": "strict-language",
  "displayName": "Strict Language",
  "description": "Strict Language Server Protocol client, see https://strict-lang.org/ for more details.",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "strict-vscode-client.run",
        "title": "Run strict"
      }
    ],
    "languages": [{
      "id": "strict",
      "aliases": ["Strict", "strict"],
      "extensions": [".strict"],
      "configuration": "./language-configuration.json"
  }],
  "grammars": [{
      "language": "strict",
      "scopeName": "source.strict",
      "path": "./syntaxes/strict.tmLanguage"
  }]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.0",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.0.1",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
